# Local dev configuration. Copy to .env (gitignored); `mage` does this for you on
# first run. These are throwaway LOCAL credentials — never reuse them anywhere.
#
# Docker Compose auto-loads .env for ${VAR} interpolation in docker-compose.yml;
# the mage targets read DATABASE_URL from it for host-run tooling (goose).

# --- Postgres (Compose) ---
POSTGRES_USER=qlab
POSTGRES_PASSWORD=qlab
POSTGRES_DB=qlab
# Host port mapped to the container's 5432.
POSTGRES_PORT=5432

# --- Host-facing database URL ---
# Used by host tooling (e.g. goose via `mage migrate`). Points at the published
# host port. The api CONTAINER uses its own URL (host "postgres") set in compose.
DATABASE_URL=postgres://qlab:qlab@localhost:5432/qlab?sslmode=disable
