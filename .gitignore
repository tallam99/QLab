# Go
backend/bin/

# Generated mocks (mockery). Not committed — regenerate with `mage genMocks`.
# Every mock file is named <interface>_mock.go.
*_mock.go

# Node
frontend/node_modules/
frontend/.env.local
# proto/ holds a tooling-only package (the TS codegen plugin); its lockfile is
# committed for reproducible generation, but node_modules is not.
proto/node_modules/

# Frontend build output (generated by frontend/build.sh; Vite's dist/ in Phase 9)
frontend/dist/

# Python (scripts/ tooling)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/

# Claude
.claude/settings.local.json

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# env file
.env
.env.*
!.env.example.json

# Editor/IDE
.vscode/
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Logs
firebase-debug.log