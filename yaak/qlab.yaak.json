        "id": "rq_listSlots00",
        "workspaceId": "wk_igZobFKXDr",
        "folderId": null,
        "name": "ListSlots",
        "description": "Connect-RPC (JSON): list a resource pool's slots for the caller's lab. A read, so it lives outside the Danger folder. Requires the dev principal headers (X-QLab-User / X-QLab-Lab); Phase 8 replaces them with a verified Firebase JWT in the Authorization header.",
        "method": "POST",
        "url": "${[ base_url ]}/qlab.v1.QlabService/ListSlots",
        "headers": [
          {
            "enabled": true,
            "id": null,
            "name": "Content-Type",
            "value": "application/json"
          },
          {
            "enabled": true,
            "id": null,
            "name": "X-QLab-User",
            "value": "${[ dev_user_id ]}"
          },
          {
            "enabled": true,
            "id": null,
            "name": "X-QLab-Lab",
            "value": "${[ dev_lab_id ]}"
          }
        ],
        "urlParameters": [],
        "authentication": {},
        "authenticationType": null,
        "body": {
          "text": "{\n  \"resourcePoolId\": \"${[ resource_pool_id ]}\"\n}"
