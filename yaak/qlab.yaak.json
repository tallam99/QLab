        "authenticationType": null,
        "headers": [
          {
            "enabled": true,
            "name": "X-Yaak-Confirm",
            "value": "${[ prompt.text(title='Run this destructive request?', label='Type the target resource id to confirm', placeholder='e.g. lab id') ]}",
            "id": null
          }
        ],
        "sortPriority": 0.0
      }
