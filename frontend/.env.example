# Frontend environment (Vite). Copy to .env.local for local dev (gitignored).
# Only VITE_-prefixed vars are exposed to the browser bundle.

# Base URL of the Connect API.
#   local   -> leave EMPTY: the app calls same-origin and the Vite proxy
#              (vite.config.ts) forwards to the Go service on :8090.
#   staging -> https://api-staging-<hash>-ue.a.run.app (cross-origin; CORS applies)
VITE_API_BASE_URL=

# Firebase web app config (Project settings -> Your apps -> Web app).
# Locally these point at the demo project the Auth emulator serves; the apiKey
# can be any non-empty placeholder because the emulator does not verify it.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-qlab.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-qlab

# Local only: point the Firebase Auth SDK at the local emulator. Leave UNSET in
# staging/prod so the SDK talks to real Firebase. Must match docker-compose's
# emulator port (9099).
VITE_FIREBASE_AUTH_EMULATOR_HOST=http://localhost:9099

# Render the dev switcher (sign-in + provision/act-as). On for local/staging;
# leave UNSET in production so the build ships a neutral placeholder.
VITE_DEV_SWITCHER=true
